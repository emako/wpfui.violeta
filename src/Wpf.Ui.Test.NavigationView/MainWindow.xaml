<vio:ShellWindow
    x:Class="Wpf.Ui.Test.NavigationView.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:compat="clr-namespace:Wpf.Ui.Violeta.Controls.Compat;assembly=Wpf.Ui.Violeta"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
    Title="Wpf.Ui.Test.NavigationView"
    Width="1480"
    Height="960"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="16,42,16,12"
            Padding="16"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,16,8">
                    <TextBlock FontWeight="SemiBold" Text="PaneDisplayMode" />
                    <ComboBox
                        x:Name="PaneDisplayModeComboBox"
                        MinWidth="160"
                        Margin="0,6,0,0"
                        SelectionChanged="PaneDisplayModeComboBox_OnSelectionChanged">
                        <ComboBoxItem IsSelected="True" Tag="{x:Static vio:NavigationViewPaneDisplayMode.Auto}">Auto</ComboBoxItem>
                        <ComboBoxItem Tag="{x:Static vio:NavigationViewPaneDisplayMode.Left}">Left</ComboBoxItem>
                        <ComboBoxItem Tag="{x:Static vio:NavigationViewPaneDisplayMode.Top}">Top</ComboBoxItem>
                        <ComboBoxItem Tag="{x:Static vio:NavigationViewPaneDisplayMode.LeftCompact}">LeftCompact</ComboBoxItem>
                        <ComboBoxItem Tag="{x:Static vio:NavigationViewPaneDisplayMode.LeftMinimal}">LeftMinimal</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,16,8">
                    <TextBlock FontWeight="SemiBold" Text="BackButton" />
                    <ComboBox
                        x:Name="BackButtonVisibilityComboBox"
                        MinWidth="140"
                        Margin="0,6,0,0"
                        SelectionChanged="BackButtonVisibilityComboBox_OnSelectionChanged">
                        <ComboBoxItem Tag="{x:Static vio:NavigationViewBackButtonVisible.Collapsed}">Collapsed</ComboBoxItem>
                        <ComboBoxItem IsSelected="True" Tag="{x:Static vio:NavigationViewBackButtonVisible.Visible}">Visible</ComboBoxItem>
                        <ComboBoxItem Tag="{x:Static vio:NavigationViewBackButtonVisible.Auto}">Auto</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,16,8">
                    <TextBlock FontWeight="SemiBold" Text="快速操作" />
                    <WrapPanel Margin="0,6,0,0">
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="TogglePaneButton_OnClick"
                            Content="切换面板" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="TogglePaneVisibilityButton_OnClick"
                            Content="切换 Pane 可见性" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ToggleSettingsButton_OnClick"
                            Content="切换设置项" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="SelectSettingsButton_OnClick"
                            Content="选中设置项" />
                    </WrapPanel>
                </StackPanel>

                <StackPanel Margin="0,0,16,8">
                    <TextBlock FontWeight="SemiBold" Text="动态菜单" />
                    <WrapPanel Margin="0,6,0,0">
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="AddDynamicItemButton_OnClick"
                            Content="新增顶层项" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="RemoveDynamicItemButton_OnClick"
                            Content="移除顶层项" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ExpandReportsButton_OnClick"
                            Content="展开 Reports" />
                    </WrapPanel>
                </StackPanel>
            </WrapPanel>
        </Border>

        <vio:NavigationView
            x:Name="TestNavigationView"
            Grid.Row="1"
            Margin="16,0,16,16"
            AlwaysShowHeader="True"
            BackRequested="TestNavigationView_OnBackRequested"
            Collapsed="TestNavigationView_OnCollapsed"
            CompactPaneLength="52"
            DisplayModeChanged="TestNavigationView_OnDisplayModeChanged"
            Expanding="TestNavigationView_OnExpanding"
            Header="NavigationView 手动测试台"
            IsBackButtonVisible="Visible"
            IsBackEnabled="True"
            IsFooterSeparatorVisible="True"
            IsPaneOpen="True"
            IsPaneToggleButtonVisible="True"
            IsPaneVisible="True"
            IsSettingsVisible="True"
            ItemInvoked="TestNavigationView_OnItemInvoked"
            OpenPaneLength="320"
            PaneClosed="TestNavigationView_OnPaneClosed"
            PaneClosing="TestNavigationView_OnPaneClosing"
            PaneOpened="TestNavigationView_OnPaneOpened"
            PaneOpening="TestNavigationView_OnPaneOpening"
            PaneTitle="Navigation Lab"
            SelectionChanged="TestNavigationView_OnSelectionChanged">

            <vio:NavigationView.PaneHeader>
                <Border
                    Margin="12,12,12,8"
                    Padding="12"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="NavigationView 场景覆盖" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="验证左侧 / 顶部模式、层级项、设置项、Pane 事件和动态菜单。" />
                    </StackPanel>
                </Border>
            </vio:NavigationView.PaneHeader>

            <vio:NavigationView.PaneCustomContent>
                <Border
                    Margin="12,0,12,8"
                    Padding="10"
                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                    CornerRadius="8">
                    <TextBlock Text="PaneCustomContent: 在 Top 模式下可观察自定义区域重新排版。" />
                </Border>
            </vio:NavigationView.PaneCustomContent>

            <vio:NavigationView.PaneFooter>
                <Border
                    Margin="12,8,12,12"
                    Padding="10"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    CornerRadius="8">
                    <TextBlock Text="PaneFooter: 检查 Footer 与 FooterMenuItems 的间距和分隔线。" />
                </Border>
            </vio:NavigationView.PaneFooter>

            <vio:NavigationView.ContentOverlay>
                <Border
                    Margin="0,12,12,0"
                    Padding="8,4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="#CC2D2D30"
                    CornerRadius="999">
                    <TextBlock Foreground="White" Text="ContentOverlay 已启用" />
                </Border>
            </vio:NavigationView.ContentOverlay>

            <vio:NavigationView.MenuItems>
                <vio:NavigationViewItem
                    x:Name="HomeItem"
                    Content="Home"
                    Tag="home">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE80F;" />
                    </vio:NavigationViewItem.Icon>
                    <vio:NavigationViewItem.InfoBadge>
                        <compat:InfoBadge Value="3" />
                    </vio:NavigationViewItem.InfoBadge>
                </vio:NavigationViewItem>

                <vio:NavigationViewItemHeader Content="Operations" />

                <vio:NavigationViewItem
                    x:Name="ReportsItem"
                    Content="Reports"
                    Tag="reports">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE9D2;" />
                    </vio:NavigationViewItem.Icon>
                    <vio:NavigationViewItem.MenuItems>
                        <vio:NavigationViewItem Content="Daily report" Tag="reports/daily">
                            <vio:NavigationViewItem.Icon>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE8FD;" />
                            </vio:NavigationViewItem.Icon>
                        </vio:NavigationViewItem>
                        <vio:NavigationViewItem Content="Weekly review" Tag="reports/weekly">
                            <vio:NavigationViewItem.Icon>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE823;" />
                            </vio:NavigationViewItem.Icon>
                        </vio:NavigationViewItem>
                        <vio:NavigationViewItem Content="Executive summary" Tag="reports/executive">
                            <vio:NavigationViewItem.Icon>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE7C3;" />
                            </vio:NavigationViewItem.Icon>
                        </vio:NavigationViewItem>
                    </vio:NavigationViewItem.MenuItems>
                </vio:NavigationViewItem>

                <vio:NavigationViewItem Content="Approvals" Tag="approvals">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE8FB;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>

                <vio:NavigationViewItem Content="Tasks" Tag="tasks">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE823;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>

                <vio:NavigationViewItemSeparator />

                <vio:NavigationViewItem Content="Analytics" Tag="analytics">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE9D9;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>
                <vio:NavigationViewItem Content="Customers" Tag="customers">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE716;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>
                <vio:NavigationViewItem Content="Orders" Tag="orders">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE8FE;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>
                <vio:NavigationViewItem Content="Billing" Tag="billing">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE8C7;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>
                <vio:NavigationViewItem Content="Inventory" Tag="inventory">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE7BF;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>
                <vio:NavigationViewItem Content="Studio" Tag="studio">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE714;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>
                <vio:NavigationViewItem Content="Timeline" Tag="timeline">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE823;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>
                <vio:NavigationViewItem Content="Experiments" Tag="experiments">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE7BE;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>
            </vio:NavigationView.MenuItems>

            <vio:NavigationView.FooterMenuItems>
                <vio:NavigationViewItem Content="Support" Tag="support">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE897;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>
                <vio:NavigationViewItem Content="Archive" Tag="archive">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE7B8;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>
            </vio:NavigationView.FooterMenuItems>

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0" Columns="3">
                    <Border
                        Margin="0,0,12,0"
                        Padding="16"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="当前选中" />
                            <TextBlock
                                x:Name="CurrentSelectionTextBlock"
                                Margin="0,8,0,0"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="-" />
                            <TextBlock
                                x:Name="CurrentSelectionDetailTextBlock"
                                Margin="0,6,0,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="等待导航事件..." />
                        </StackPanel>
                    </Border>

                    <Border
                        Margin="0,0,12,0"
                        Padding="16"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="显示状态" />
                            <TextBlock
                                x:Name="CurrentDisplayModeTextBlock"
                                Margin="0,8,0,0"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="-" />
                            <TextBlock
                                x:Name="PaneStateTextBlock"
                                Margin="0,6,0,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="Pane 状态未知" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="16"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="最近事件" />
                            <TextBlock
                                x:Name="LastEventTextBlock"
                                Margin="0,8,0,0"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="-" />
                            <TextBlock
                                Margin="0,6,0,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="通过顶部按钮快速切换状态，并观察事件顺序。" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="16"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Text="建议验证清单" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="1. 切到 Top 模式，确认主菜单出现溢出按钮。 2. 折叠/展开 Reports，检查层级项动画、事件和选中状态。 3. 切换 Pane 可见性、设置项和 BackButton 可见性，观察模板更新。"
                                    TextWrapping="Wrap" />

                                <Separator Margin="0,16,0,16" />

                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="内容区域" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    Text="这个页面不是业务示例，而是控件验收台。重点是快速覆盖 NavigationView 的主要视觉状态和事件路径。"
                                    TextWrapping="Wrap" />

                                <WrapPanel Margin="0,16,0,0">
                                    <ui:Button
                                        Margin="0,0,8,8"
                                        Click="SelectHomeButton_OnClick"
                                        Content="选中 Home" />
                                    <ui:Button
                                        Margin="0,0,8,8"
                                        Click="SelectReportsChildButton_OnClick"
                                        Content="选中 Daily report" />
                                    <ui:Button
                                        Margin="0,0,8,8"
                                        Click="ClearLogButton_OnClick"
                                        Content="清空日志" />
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="16"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="事件日志" />
                            <ListBox
                                x:Name="EventLogListBox"
                                Grid.Row="2"
                                HorizontalContentAlignment="Stretch" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </vio:NavigationView>
    </Grid>
</vio:ShellWindow>