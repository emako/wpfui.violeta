<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Preview style – displayed while dragging (ShowsPreview=True).
        The actual resize only fires on mouse release, matching Semi.Avalonia behavior.
    -->
    <Style x:Key="GridSplitterPreviewStyle">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border
                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                        CornerRadius="3"
                        Opacity="0.35" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Default GridSplitter style.
        
        Key features
        • ShowsPreview = True  →  size only changes on mouse release (松开后生效)
        • Transparent hit-test padding so the grab area is wider than the visual bar
        • Accent-colored hover / focus state
        • Subtle grip dots that adapt to horizontal / vertical orientation via triggers
    -->
    <Style TargetType="{x:Type GridSplitter}">
        <!--  Defer resize until mouse released  -->
        <Setter Property="ShowsPreview" Value="True" />
        <!--<Setter Property="MinWidth" Value="6" />-->
        <!--<Setter Property="MinHeight" Value="6" />-->
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="PreviewStyle" Value="{StaticResource GridSplitterPreviewStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GridSplitter}">
                    <!--  Outer Border: transparent, provides comfortable grab area  -->
                    <Border
                        x:Name="Root"
                        Padding="2"
                        Background="Transparent"
                        SnapsToDevicePixels="True">
                        <!--  Visual bar  -->
                        <Border
                            x:Name="Bar"
                            Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                            CornerRadius="3">
                            <Grid
                                x:Name="GripGrid"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <!--  Horizontal grip: 3 dots in a row (used when splitter separates columns)  -->
                                <StackPanel
                                    x:Name="HGrip"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                                    <Ellipse
                                        Width="3"
                                        Height="3"
                                        Margin="1,0"
                                        Fill="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <Ellipse
                                        Width="3"
                                        Height="3"
                                        Margin="1,0"
                                        Fill="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <Ellipse
                                        Width="3"
                                        Height="3"
                                        Margin="1,0"
                                        Fill="{DynamicResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                                <!--  Vertical grip: 3 dots in a column (used when splitter separates rows)  -->
                                <StackPanel
                                    x:Name="VGrip"
                                    Orientation="Vertical"
                                    Visibility="Collapsed">
                                    <Ellipse
                                        Width="3"
                                        Height="3"
                                        Margin="0,1"
                                        Fill="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <Ellipse
                                        Width="3"
                                        Height="3"
                                        Margin="0,1"
                                        Fill="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <Ellipse
                                        Width="3"
                                        Height="3"
                                        Margin="0,1"
                                        Fill="{DynamicResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!--  Show appropriate grip based on cursor (set by WPF based on splitter direction)  -->
                        <Trigger Property="Cursor" Value="SizeNS">
                            <Setter TargetName="VGrip" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Cursor" Value="SizeWE">
                            <Setter TargetName="HGrip" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!--  Hover  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bar" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            <Setter TargetName="HGrip" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="VGrip" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!--  Keyboard focus  -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bar" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            <Setter TargetName="HGrip" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="VGrip" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!--  Disabled  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
