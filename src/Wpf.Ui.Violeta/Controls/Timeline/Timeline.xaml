<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Wpf.Ui.Violeta.Controls">

    <local:TimelineFormatConverter x:Key="TimelineFormatConverter" />

    <!--  Timeline (container only — layout is delegated to TimelinePanel)  -->
    <Style x:Key="DefaultTimelineStyle" TargetType="{x:Type local:Timeline}">
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <local:TimelinePanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Timeline}">
                    <ItemsPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource DefaultTimelineStyle}" TargetType="{x:Type local:Timeline}" />

    <!--  TimelineItem  -->
    <Style x:Key="DefaultTimelineItemStyle" TargetType="{x:Type local:TimelineItem}">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TimelineItem}">
                    <Grid x:Name="PART_RootGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Icon + connector line (col 1, row 0-2)  -->
                        <Grid
                            x:Name="PART_IconAxisRoot"
                            Grid.RowSpan="3"
                            Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  Icon area  -->
                            <Grid x:Name="PART_Icon" Grid.Row="0">
                                <ContentPresenter
                                    Margin="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding Icon}"
                                    ContentTemplate="{TemplateBinding IconTemplate}" />
                                <Ellipse
                                    x:Name="PART_DefaultIcon"
                                    Width="12"
                                    Height="12"
                                    Margin="8"
                                    Fill="{DynamicResource SubtleFillColorSecondaryBrush}"
                                    Visibility="Collapsed" />
                            </Grid>

                            <!--  Connector line  -->
                            <Rectangle
                                x:Name="PART_Line"
                                Grid.Row="1"
                                Width="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Fill="{DynamicResource ControlElevationBorderBrush}" />
                        </Grid>

                        <!--  Header (default: col 2 row 0)  -->
                        <ContentPresenter
                            x:Name="PART_Header"
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="8,4"
                            VerticalAlignment="Top"
                            Content="{TemplateBinding Header}"
                            ContentTemplate="{TemplateBinding HeaderTemplate}"
                            TextBlock.FontSize="14"
                            TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <!--  Content (default: col 2 row 1)  -->
                        <ContentPresenter
                            x:Name="PART_Content"
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="8,2"
                            VerticalAlignment="Top"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            TextElement.FontSize="12"
                            TextElement.Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                        <!--  Time (default: col 0 row 0)  -->
                        <TextBlock
                            x:Name="PART_Time"
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="8,4"
                            VerticalAlignment="Top"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            TextWrapping="Wrap">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource TimelineFormatConverter}">
                                    <Binding Path="Time" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="TimeFormat" RelativeSource="{RelativeSource TemplatedParent}" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  Last item: hide connector line  -->
                        <Trigger Property="IsLast" Value="True">
                            <Setter TargetName="PART_Line" Property="Fill" Value="Transparent" />
                        </Trigger>

                        <!--  No custom icon: show default dot  -->
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="PART_DefaultIcon" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!--  Type-based dot colors  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Icon" Value="{x:Null}" />
                                <Condition Property="Type" Value="Default" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_DefaultIcon" Property="Fill" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Icon" Value="{x:Null}" />
                                <Condition Property="Type" Value="Ongoing" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_DefaultIcon" Property="Fill" Value="{DynamicResource SystemFillColorAttentionBrush}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Icon" Value="{x:Null}" />
                                <Condition Property="Type" Value="Success" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_DefaultIcon" Property="Fill" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Icon" Value="{x:Null}" />
                                <Condition Property="Type" Value="Warning" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_DefaultIcon" Property="Fill" Value="{DynamicResource SystemFillColorCautionBrush}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Icon" Value="{x:Null}" />
                                <Condition Property="Type" Value="Error" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_DefaultIcon" Property="Fill" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                        </MultiTrigger>

                        <!--  Position = Left: Header/Content in col 2, Time in col 2 row 2  -->
                        <Trigger Property="Position" Value="Left">
                            <Setter TargetName="PART_Header" Property="Grid.Row" Value="0" />
                            <Setter TargetName="PART_Header" Property="Grid.Column" Value="2" />
                            <Setter TargetName="PART_Header" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="PART_Content" Property="Grid.Row" Value="1" />
                            <Setter TargetName="PART_Content" Property="Grid.Column" Value="2" />
                            <Setter TargetName="PART_Content" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="PART_Time" Property="Grid.Row" Value="2" />
                            <Setter TargetName="PART_Time" Property="Grid.Column" Value="2" />
                            <Setter TargetName="PART_Time" Property="TextAlignment" Value="Left" />
                            <Setter TargetName="PART_Time" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="PART_Time" Property="Margin" Value="8,2,8,12" />
                        </Trigger>

                        <!--  Position = Right: Header/Content in col 0, Time in col 0 row 2  -->
                        <Trigger Property="Position" Value="Right">
                            <Setter TargetName="PART_Header" Property="Grid.Row" Value="0" />
                            <Setter TargetName="PART_Header" Property="Grid.Column" Value="0" />
                            <Setter TargetName="PART_Header" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="PART_Content" Property="Grid.Row" Value="1" />
                            <Setter TargetName="PART_Content" Property="Grid.Column" Value="0" />
                            <Setter TargetName="PART_Content" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="PART_Time" Property="Grid.Row" Value="2" />
                            <Setter TargetName="PART_Time" Property="Grid.Column" Value="0" />
                            <Setter TargetName="PART_Time" Property="TextAlignment" Value="Right" />
                            <Setter TargetName="PART_Time" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="PART_Time" Property="Margin" Value="8,2,8,12" />
                        </Trigger>

                        <!--  Position = Separate: Content in col 2, Time in col 0  -->
                        <Trigger Property="Position" Value="Separate">
                            <Setter TargetName="PART_Header" Property="Grid.Row" Value="0" />
                            <Setter TargetName="PART_Header" Property="Grid.Column" Value="2" />
                            <Setter TargetName="PART_Header" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="PART_Content" Property="Grid.Row" Value="1" />
                            <Setter TargetName="PART_Content" Property="Grid.Column" Value="2" />
                            <Setter TargetName="PART_Content" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="PART_Content" Property="Margin" Value="8,2,8,12" />
                            <Setter TargetName="PART_Time" Property="Grid.Row" Value="0" />
                            <Setter TargetName="PART_Time" Property="Grid.Column" Value="0" />
                            <Setter TargetName="PART_Time" Property="TextAlignment" Value="Right" />
                            <Setter TargetName="PART_Time" Property="HorizontalAlignment" Value="Right" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource DefaultTimelineItemStyle}" TargetType="{x:Type local:TimelineItem}" />

</ResourceDictionary>
