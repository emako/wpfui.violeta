<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Wpf.Ui.Violeta.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Wpf.Ui.Violeta;component/Controls/DateTimePicker/DateTimePicker.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        ═══════════════════════════════════════════════════════════════
        ValuePickerPresenter
        ═══════════════════════════════════════════════════════════════
    -->
    <Style TargetType="{x:Type local:ValuePickerPresenter}">
        <Setter Property="Width" Value="300" />
        <Setter Property="MinWidth" Value="240" />
        <Setter Property="MaxHeight" Value="300" />
        <Setter Property="Background" Value="{DynamicResource DateTimePickerPopupBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DateTimePickerPopupBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ValuePickerPresenter}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource DateTimePickerPopupCornerRadius}"
                        Effect="{DynamicResource DateTimePickerPopupShadow}"
                        SnapsToDevicePixels="True">
                        <Border ClipToBounds="True" CornerRadius="{DynamicResource DateTimePickerPopupCornerRadius}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid
                                    x:Name="PART_PickerContainer"
                                    Grid.Row="0"
                                    Height="180" />

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="1" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Rectangle
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3"
                                        Height="1"
                                        VerticalAlignment="Top"
                                        Fill="{DynamicResource DateTimePickerSeparatorBackground}" />

                                    <Button
                                        x:Name="PART_AcceptButton"
                                        Grid.Column="0"
                                        Height="40"
                                        HorizontalAlignment="Stretch"
                                        Style="{StaticResource DateTimePickerPopupButtonStyle}">
                                        <Path
                                            Width="14"
                                            Height="10"
                                            Data="M 0,5 L 5,10 L 14,0"
                                            Stretch="Fill"
                                            Stroke="{DynamicResource DateTimePickerFlyoutButtonForeground}"
                                            StrokeLineJoin="Round"
                                            StrokeThickness="1.8" />
                                    </Button>

                                    <Rectangle Grid.Column="1" Fill="{DynamicResource DateTimePickerSeparatorBackground}" />

                                    <Button
                                        x:Name="PART_DismissButton"
                                        Grid.Column="2"
                                        Height="40"
                                        HorizontalAlignment="Stretch"
                                        Style="{StaticResource DateTimePickerPopupButtonStyle}">
                                        <Path
                                            Width="10"
                                            Height="10"
                                            Data="M 0,0 L 10,10 M 0,10 L 10,0"
                                            Stretch="Fill"
                                            Stroke="{DynamicResource DateTimePickerFlyoutButtonForeground}"
                                            StrokeThickness="1.5" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════════
        ValuePicker
        ═══════════════════════════════════════════════════════════════
    -->
    <Style TargetType="{x:Type local:ValuePicker}">
        <Setter Property="Foreground" Value="{DynamicResource DateTimePickerButtonForeground}" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="MinWidth" Value="220" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ValuePicker}">
                    <StackPanel>
                        <ContentPresenter
                            x:Name="HeaderPresenter"
                            Margin="0,0,0,4"
                            Content="{TemplateBinding Header}"
                            ContentTemplate="{TemplateBinding HeaderTemplate}"
                            Visibility="Collapsed" />

                        <Grid>
                            <Button
                                x:Name="PART_FlyoutButton"
                                MinWidth="{TemplateBinding MinWidth}"
                                MinHeight="{TemplateBinding MinHeight}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Foreground="{TemplateBinding Foreground}"
                                IsEnabled="{TemplateBinding IsEnabled}"
                                Style="{StaticResource DateTimePickerFlyoutButtonStyle}">
                                <Grid x:Name="PART_ButtonContentGrid">
                                    <TextBlock
                                        x:Name="PART_IconTextBlock"
                                        Width="32"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FluentSystemIcons}"
                                        FontSize="16"
                                        Foreground="{DynamicResource DateTimePickerIconForeground}"
                                        Text="{TemplateBinding IconGlyph}" />
                                </Grid>
                            </Button>

                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=PART_FlyoutButton}"
                                PopupAnimation="Fade"
                                StaysOpen="False">
                                <local:ValuePickerPresenter x:Name="PART_Presenter" />
                            </Popup>
                        </Grid>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                            <Setter TargetName="HeaderPresenter" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
