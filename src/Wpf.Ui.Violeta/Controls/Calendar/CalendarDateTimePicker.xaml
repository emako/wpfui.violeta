<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:chelper="clr-namespace:Wpf.Ui.Violeta.Controls.Compat"
    xmlns:local="clr-namespace:Wpf.Ui.Violeta.Controls"
    xmlns:primitives="clr-namespace:Wpf.Ui.Violeta.Controls.Compat">

    <!--
        CalendarDateTimePicker mirrors CalendarDatePicker's TextBox + drop-down button
        structure, but its popup renders a Calendar side-by-side with a TimePickerPresenter,
        so a single control can pick both date and time.
    -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Wpf.Ui.Violeta;component/Controls/Calendar/Calendar.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Wpf.Ui.Violeta;component/Controls/DateTimePicker/DateTimePicker.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Wpf.Ui.Violeta;component/Controls/DateTimePicker/TimePicker.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        ═══════════════════════════════════════════════════════════════
        TimePickerPresenter template flavor for CalendarDateTimePicker:
        just the hour/minute/second/period columns, without its own
        Border/shadow/Accept-Dismiss row (the outer popup supplies those).
        ═══════════════════════════════════════════════════════════════
    -->
    <ControlTemplate x:Key="CalendarDateTimePickerTimePresenterTemplate" TargetType="{x:Type local:TimePickerPresenter}">
        <!--
            Height is pinned to VisibleItemCount * ItemHeight (11 * 36 = 396, set by the
            instantiating style below) so the ScrollViewer's actual viewport always matches
            what DateTimePickerPanel's centering/scroll math assumes. Without an explicit
            height here, the ScrollViewer measures to full content size (e.g. 24 hours tall)
            and gets stretched/clipped by the surrounding layout instead — which desyncs the
            "selected item lands in the middle" math from the actual viewport size.
        -->
        <Grid
            x:Name="PART_PickerContainer"
            Width="180"
            Height="396"
            VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Hour column  -->
            <local:DateTimePickerPanel
                x:Name="PART_HourSelector"
                Grid.Column="0"
                ItemHeight="36"
                PanelType="Hour"
                ShouldLoop="True" />

            <!--  Separator 1  -->
            <Rectangle Grid.Column="1" Fill="{DynamicResource DateTimePickerSeparatorBackground}" />

            <!--  Minute column  -->
            <local:DateTimePickerPanel
                x:Name="PART_MinuteSelector"
                Grid.Column="2"
                ItemHeight="36"
                PanelType="Minute"
                ShouldLoop="True" />

            <!--  Separator 2 (only when UseSeconds=True)  -->
            <Rectangle
                x:Name="PART_SecondSpacer"
                Grid.Column="3"
                Width="1"
                Fill="{DynamicResource DateTimePickerSeparatorBackground}"
                Visibility="Collapsed" />

            <!--  Second column (only when UseSeconds=True)  -->
            <local:DateTimePickerPanel
                x:Name="PART_SecondSelector"
                Grid.Column="4"
                Width="60"
                ItemHeight="36"
                PanelType="Second"
                ShouldLoop="True"
                Visibility="Collapsed" />

            <!--  Separator 3 (12h period)  -->
            <Rectangle
                x:Name="PART_PeriodSpacer"
                Grid.Column="5"
                Width="1"
                Fill="{DynamicResource DateTimePickerSeparatorBackground}"
                Visibility="Collapsed" />

            <!--  Period column (AM/PM) only for 12h  -->
            <local:DateTimePickerPanel
                x:Name="PART_PeriodSelector"
                Grid.Column="6"
                Width="52"
                ItemHeight="36"
                PanelType="TimePeriod"
                ShouldLoop="False"
                Visibility="Collapsed" />
        </Grid>
        <ControlTemplate.Triggers>
            <!--  Show seconds  -->
            <DataTrigger Binding="{Binding UseSeconds, RelativeSource={RelativeSource Self}}" Value="True">
                <Setter TargetName="PART_SecondSelector" Property="Visibility" Value="Visible" />
                <Setter TargetName="PART_SecondSpacer" Property="Visibility" Value="Visible" />
            </DataTrigger>
            <!--  Show AM/PM for 12h  -->
            <DataTrigger Binding="{Binding ClockIdentifier, RelativeSource={RelativeSource Self}}" Value="12HourClock">
                <Setter TargetName="PART_PeriodSelector" Property="Visibility" Value="Visible" />
                <Setter TargetName="PART_PeriodSpacer" Property="Visibility" Value="Visible" />
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!--
        ═══════════════════════════════════════════════════════════════
        CalendarDateTimePicker
        ═══════════════════════════════════════════════════════════════
    -->
    <Style x:Key="DefaultCalendarDateTimePickerStyle" TargetType="{x:Type local:CalendarDateTimePicker}">
        <Setter Property="Foreground" Value="{DynamicResource CalendarDatePickerTextForegroundSelected}" />
        <Setter Property="Background" Value="{DynamicResource TextControlBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextControlElevationBorderBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource TextBoxBorderThemeThickness}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
        <Setter Property="Padding" Value="{DynamicResource TextControlThemePadding}" />
        <Setter Property="MinHeight" Value="{DynamicResource TextControlThemeMinHeight}" />
        <Setter Property="MinWidth" Value="220" />
        <Setter Property="chelper:ControlHelper.CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:CalendarDateTimePicker}">
                    <StackPanel>
                        <!--  Optional header  -->
                        <ContentPresenter
                            x:Name="HeaderPresenter"
                            Margin="0,0,0,4"
                            Content="{TemplateBinding Header}"
                            ContentTemplate="{TemplateBinding HeaderTemplate}"
                            Visibility="Collapsed" />

                        <Grid x:Name="PART_Root" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="32" />
                            </Grid.ColumnDefinitions>
                            <Border
                                x:Name="ContentBorder"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                MinWidth="{TemplateBinding MinWidth}"
                                MinHeight="{TemplateBinding MinHeight}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding chelper:ControlHelper.CornerRadius}" />
                            <Grid Grid.Column="0" Grid.ColumnSpan="2">
                                <TextBox
                                    x:Name="PART_TextBox"
                                    Padding="{TemplateBinding Padding}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CaretBrush="{TemplateBinding Foreground}"
                                    Focusable="{TemplateBinding Focusable}"
                                    FontSize="{TemplateBinding FontSize}"
                                    Foreground="{TemplateBinding Foreground}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden" />
                                <TextBlock
                                    x:Name="PART_PlaceholderText"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    FontSize="{TemplateBinding FontSize}"
                                    Foreground="{DynamicResource CalendarDatePickerTextForeground}"
                                    IsHitTestVisible="False"
                                    Text="{TemplateBinding PlaceholderText}"
                                    Visibility="Collapsed" />
                            </Grid>
                            <Button
                                x:Name="PART_Button"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Content="&#xE252;"
                                Focusable="False"
                                FontFamily="{DynamicResource FluentSystemIcons}"
                                FontSize="12"
                                Foreground="{DynamicResource CalendarDatePickerCalendarGlyphForeground}">
                                <Button.Template>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <TextBlock
                                            HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                            FontFamily="{TemplateBinding FontFamily}"
                                            FontSize="{TemplateBinding FontSize}"
                                            Foreground="{TemplateBinding Foreground}"
                                            Text="{TemplateBinding Content}" />
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Popup
                                x:Name="PART_Popup"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                AllowsTransparency="True"
                                Placement="Bottom"
                                StaysOpen="False">
                                <primitives:ThemeShadowChrome
                                    x:Name="Shdw"
                                    chelper:OpeningAnimationHelper.Storyboard="{DynamicResource CalendarDateTimePickerOpeningStoryboard}"
                                    CornerRadius="{DynamicResource DateTimePickerPopupCornerRadius}"
                                    IsShadowEnabled="True"
                                    SnapsToDevicePixels="True">
                                    <primitives:ThemeShadowChrome.Resources>
                                        <Storyboard x:Key="CalendarDateTimePickerOpeningStoryboard">
                                            <DoubleAnimation
                                                Storyboard.Target="{Binding ElementName=Shdw}"
                                                Storyboard.TargetProperty="Opacity"
                                                From="0"
                                                To="1"
                                                Duration="0:0:0.100" />
                                        </Storyboard>
                                    </primitives:ThemeShadowChrome.Resources>
                                    <Border
                                        Background="{DynamicResource DateTimePickerPopupBackground}"
                                        BorderBrush="{DynamicResource DateTimePickerPopupBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource DateTimePickerPopupCornerRadius}"
                                        SnapsToDevicePixels="True">
                                        <Border ClipToBounds="True" CornerRadius="{DynamicResource DateTimePickerPopupCornerRadius}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!--  Calendar + Time picker side by side  -->
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="1" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Calendar
                                                        x:Name="PART_Calendar"
                                                        Grid.Column="0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        IsTodayHighlighted="True" />

                                                    <Rectangle Grid.Column="1" Fill="{DynamicResource DateTimePickerSeparatorBackground}" />

                                                    <local:TimePickerPresenter
                                                        x:Name="PART_TimePresenter"
                                                        Grid.Column="2"
                                                        Width="Auto"
                                                        Height="Auto"
                                                        MinWidth="0"
                                                        VerticalAlignment="Center"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        ClockIdentifier="{Binding ClockIdentifier, RelativeSource={RelativeSource TemplatedParent}}"
                                                        Template="{StaticResource CalendarDateTimePickerTimePresenterTemplate}"
                                                        UseSeconds="{Binding UseSeconds, RelativeSource={RelativeSource TemplatedParent}}"
                                                        VisibleItemCount="11" />
                                                </Grid>

                                                <!--  Accept / Dismiss row  -->
                                                <Grid Grid.Row="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="1" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Rectangle
                                                        Grid.Column="0"
                                                        Grid.ColumnSpan="3"
                                                        Height="1"
                                                        VerticalAlignment="Top"
                                                        Fill="{DynamicResource DateTimePickerSeparatorBackground}" />

                                                    <Button
                                                        x:Name="PART_AcceptButton"
                                                        Grid.Column="0"
                                                        Height="40"
                                                        HorizontalAlignment="Stretch"
                                                        Style="{StaticResource DateTimePickerPopupButtonStyle}">
                                                        <Path
                                                            Width="14"
                                                            Height="10"
                                                            Data="M 0,5 L 5,10 L 14,0"
                                                            Stretch="Fill"
                                                            Stroke="{DynamicResource DateTimePickerFlyoutButtonForeground}"
                                                            StrokeLineJoin="Round"
                                                            StrokeThickness="1.8" />
                                                    </Button>

                                                    <Rectangle Grid.Column="1" Fill="{DynamicResource DateTimePickerSeparatorBackground}" />

                                                    <Button
                                                        x:Name="PART_DismissButton"
                                                        Grid.Column="2"
                                                        Height="40"
                                                        HorizontalAlignment="Stretch"
                                                        Style="{StaticResource DateTimePickerPopupButtonStyle}">
                                                        <Path
                                                            Width="10"
                                                            Height="10"
                                                            Data="M 0,0 L 10,10 M 0,10 L 10,0"
                                                            Stretch="Fill"
                                                            Stroke="{DynamicResource DateTimePickerFlyoutButtonForeground}"
                                                            StrokeThickness="1.5" />
                                                    </Button>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Border>
                                </primitives:ThemeShadowChrome>
                            </Popup>

                            <!--  Accent border / bottom focus indicator  -->
                            <Border
                                x:Name="AccentBorder"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="{DynamicResource TextBoxAccentBorderThemeThickness}"
                                CornerRadius="{TemplateBinding chelper:ControlHelper.CornerRadius}"
                                IsHitTestVisible="False" />
                        </Grid>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                            <Setter TargetName="HeaderPresenter" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <Trigger SourceName="PART_TextBox" Property="Text" Value="">
                            <Setter TargetName="PART_PlaceholderText" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger SourceName="PART_TextBox" Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="AccentBorder" Property="BorderThickness" Value="0,0,0,2" />
                            <Setter TargetName="AccentBorder" Property="BorderBrush" Value="{DynamicResource TextControlFocusedBorderBrush}" />
                            <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource TextControlBackgroundFocused}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="True" />
                                <Condition SourceName="PART_Root" Property="IsMouseOver" Value="True" />
                                <Condition SourceName="PART_TextBox" Property="IsKeyboardFocused" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource TextControlBackgroundPointerOver}" />
                        </MultiTrigger>
                        <Trigger SourceName="PART_Button" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Button" Property="Foreground" Value="{DynamicResource CalendarDatePickerCalendarGlyphForegroundPointerOver}" />
                        </Trigger>
                        <Trigger SourceName="PART_Button" Property="IsPressed" Value="True">
                            <Setter TargetName="PART_Button" Property="Foreground" Value="{DynamicResource CalendarDatePickerCalendarGlyphForegroundPressed}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource TextControlBackgroundDisabled}" />
                            <Setter TargetName="ContentBorder" Property="BorderBrush" Value="{DynamicResource TextControlBorderBrushDisabled}" />
                            <Setter TargetName="AccentBorder" Property="BorderBrush" Value="{DynamicResource TextControlBorderBrushDisabled}" />
                            <Setter TargetName="PART_TextBox" Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                            <Setter TargetName="PART_PlaceholderText" Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                            <Setter TargetName="PART_Button" Property="Foreground" Value="{DynamicResource CalendarDatePickerCalendarGlyphForegroundDisabled}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource DefaultCalendarDateTimePickerStyle}" TargetType="{x:Type local:CalendarDateTimePicker}" />

</ResourceDictionary>
