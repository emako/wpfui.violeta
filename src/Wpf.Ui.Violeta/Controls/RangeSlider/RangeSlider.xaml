<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Wpf.Ui.Violeta.Controls">

    <!--
        Thumb style – mirrors WPF-UI's UiSliderThumbStyle
    -->
    <Style x:Key="RangeSliderThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SliderThumbBackground}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource SliderOuterThumbBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border
                        x:Name="ThumbBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="16">
                        <Ellipse
                            x:Name="ThumbEllipse"
                            Width="12"
                            Height="12"
                            Fill="{TemplateBinding Foreground}"
                            Stroke="Transparent"
                            StrokeThickness="0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbEllipse" Property="Fill" Value="{DynamicResource SliderThumbBackgroundPointerOver}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.8" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Horizontal RangeSlider template
    -->
    <ControlTemplate x:Key="UiHorizontalRangeSlider" TargetType="{x:Type local:RangeSlider}">
        <Grid x:Name="RootGrid" SnapsToDevicePixels="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Top tick bar  -->
            <TickBar
                x:Name="PART_TopTick"
                Grid.Row="0"
                Height="6"
                Fill="{DynamicResource SliderTickBarFill}"
                Maximum="{TemplateBinding Maximum}"
                Minimum="{TemplateBinding Minimum}"
                Placement="Top"
                SnapsToDevicePixels="True"
                TickFrequency="{TemplateBinding TickFrequency}"
                Visibility="Collapsed" />

            <!--  Track background (full grey bar)  -->
            <Border
                x:Name="TrackBackground"
                Grid.Row="1"
                Height="4"
                Margin="0"
                Background="{DynamicResource SliderTrackFill}"
                BorderThickness="0"
                CornerRadius="2"
                IsHitTestVisible="False" />

            <!--  RangeTrack – manages selection range + thumbs  -->
            <local:RangeTrack
                x:Name="PART_Track"
                Grid.Row="1"
                LowerValue="{Binding LowerValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                Maximum="{TemplateBinding Maximum}"
                Minimum="{TemplateBinding Minimum}"
                Orientation="{TemplateBinding Orientation}"
                SelectionRangeFill="{DynamicResource SystemAccentColorBrush}"
                UpperValue="{Binding UpperValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                <local:RangeTrack.LowerThumb>
                    <Thumb x:Name="PART_LowerThumb" Style="{StaticResource RangeSliderThumbStyle}" />
                </local:RangeTrack.LowerThumb>
                <local:RangeTrack.UpperThumb>
                    <Thumb x:Name="PART_UpperThumb" Style="{StaticResource RangeSliderThumbStyle}" />
                </local:RangeTrack.UpperThumb>
            </local:RangeTrack>

            <!--  Bottom tick bar  -->
            <TickBar
                x:Name="PART_BottomTick"
                Grid.Row="2"
                Height="6"
                Fill="{DynamicResource SliderTickBarFill}"
                Maximum="{TemplateBinding Maximum}"
                Minimum="{TemplateBinding Minimum}"
                Placement="Bottom"
                SnapsToDevicePixels="True"
                TickFrequency="{TemplateBinding TickFrequency}"
                Visibility="Collapsed" />
        </Grid>
        <ControlTemplate.Triggers>
            <!--  Track pointer-over: highlight track fill  -->
            <Trigger SourceName="PART_Track" Property="IsMouseOver" Value="True">
                <Setter TargetName="TrackBackground" Property="Background" Value="{DynamicResource SliderTrackFillPointerOver}" />
            </Trigger>

            <!--  Tick placement  -->
            <Trigger Property="TickPlacement" Value="TopLeft">
                <Setter TargetName="PART_TopTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="BottomRight">
                <Setter TargetName="PART_BottomTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="Both">
                <Setter TargetName="PART_TopTick" Property="Visibility" Value="Visible" />
                <Setter TargetName="PART_BottomTick" Property="Visibility" Value="Visible" />
            </Trigger>

            <!--  Disabled state  -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="RootGrid" Property="Opacity" Value="0.4" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!--
        Vertical RangeSlider template
    -->
    <ControlTemplate x:Key="UiVerticalRangeSlider" TargetType="{x:Type local:RangeSlider}">
        <Grid x:Name="RootGrid" SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" MinWidth="{TemplateBinding MinWidth}" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Left tick bar  -->
            <TickBar
                x:Name="PART_LeftTick"
                Grid.Column="0"
                Width="6"
                Fill="{DynamicResource SliderTickBarFill}"
                Maximum="{TemplateBinding Maximum}"
                Minimum="{TemplateBinding Minimum}"
                Placement="Left"
                SnapsToDevicePixels="True"
                TickFrequency="{TemplateBinding TickFrequency}"
                Visibility="Collapsed" />

            <!--  Track background  -->
            <Border
                x:Name="TrackBackground"
                Grid.Column="1"
                Width="4"
                Margin="0"
                Background="{DynamicResource SliderTrackFill}"
                BorderThickness="0"
                CornerRadius="2"
                IsHitTestVisible="False" />

            <!--  RangeTrack  -->
            <local:RangeTrack
                x:Name="PART_Track"
                Grid.Column="1"
                LowerValue="{Binding LowerValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                Maximum="{TemplateBinding Maximum}"
                Minimum="{TemplateBinding Minimum}"
                Orientation="{TemplateBinding Orientation}"
                SelectionRangeFill="{DynamicResource SystemAccentColorBrush}"
                UpperValue="{Binding UpperValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                <local:RangeTrack.LowerThumb>
                    <Thumb x:Name="PART_LowerThumb" Style="{StaticResource RangeSliderThumbStyle}" />
                </local:RangeTrack.LowerThumb>
                <local:RangeTrack.UpperThumb>
                    <Thumb x:Name="PART_UpperThumb" Style="{StaticResource RangeSliderThumbStyle}" />
                </local:RangeTrack.UpperThumb>
            </local:RangeTrack>

            <!--  Right tick bar  -->
            <TickBar
                x:Name="PART_RightTick"
                Grid.Column="2"
                Width="6"
                Fill="{DynamicResource SliderTickBarFill}"
                Maximum="{TemplateBinding Maximum}"
                Minimum="{TemplateBinding Minimum}"
                Placement="Right"
                SnapsToDevicePixels="True"
                TickFrequency="{TemplateBinding TickFrequency}"
                Visibility="Collapsed" />
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger SourceName="PART_Track" Property="IsMouseOver" Value="True">
                <Setter TargetName="TrackBackground" Property="Background" Value="{DynamicResource SliderTrackFillPointerOver}" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="TopLeft">
                <Setter TargetName="PART_LeftTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="BottomRight">
                <Setter TargetName="PART_RightTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="Both">
                <Setter TargetName="PART_LeftTick" Property="Visibility" Value="Visible" />
                <Setter TargetName="PART_RightTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="RootGrid" Property="Opacity" Value="0.4" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!--
        Default Style
    -->
    <Style TargetType="{x:Type local:RangeSlider}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="MinWidth" Value="104" />
                <Setter Property="MinHeight" Value="21" />
                <Setter Property="Template" Value="{StaticResource UiHorizontalRangeSlider}" />
            </Trigger>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="MinWidth" Value="21" />
                <Setter Property="MinHeight" Value="104" />
                <Setter Property="Template" Value="{StaticResource UiVerticalRangeSlider}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
