<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
    xmlns:local="clr-namespace:Wpf.Ui.Violeta.Controls">

    <!--
        LoadingButton — spinning arc indicator in Left / Right / Top / Bottom position.
        
        Arc geometry: 14 × 14 Ellipse, StrokeThickness = 2, Radius ≈ 6
        Circumference = 2π × 6 ≈ 37.7 px  →  in StrokeThickness units ≈ 18.85
        300° arc  →  dash = 18.85 × (300/360) ≈ 15.71,  gap ≈ 3.14
        
        Matches the Ursa.Avalonia LoadingIcon 300° / 0.6 s concept, adapted for WPF.
    -->

    <Style
        x:Key="DefaultLoadingButtonStyle"
        BasedOn="{StaticResource DefaultUiButtonStyle}"
        TargetType="{x:Type local:LoadingButton}">

        <!--  Override only the Template; all other Setters and Style.Triggers are inherited.  -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:LoadingButton}">
                    <Border
                        x:Name="ContentBorder"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        MinWidth="{TemplateBinding MinWidth}"
                        MinHeight="{TemplateBinding MinHeight}"
                        HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalAlignment}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="0"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <Border
                            x:Name="InsetBorder"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            BorderBrush="{Binding ElementName=ContentBorder, Path=BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">

                            <!--
                                DockPanel layout:
                                Collapsed spinners consume no space.
                                Visible spinner is automatically pushed to its docked edge,
                                leaving the rest of the area for the icon + content grid.
                            -->
                            <DockPanel
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                LastChildFill="True">

                                <!--  Left spinner  -->
                                <Grid
                                    x:Name="PART_SpinnerLeft"
                                    Width="14"
                                    Height="14"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Left"
                                    RenderTransformOrigin="0.5,0.5"
                                    Visibility="Collapsed">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="SpinnerLeftRotate" Angle="0" />
                                    </Grid.RenderTransform>
                                    <Ellipse
                                        StrokeDashArray="15.71 3.14"
                                        StrokeDashCap="Round"
                                        StrokeThickness="2">
                                        <Ellipse.Stroke>
                                            <Binding Path="Foreground" RelativeSource="{RelativeSource TemplatedParent}" />
                                        </Ellipse.Stroke>
                                    </Ellipse>
                                </Grid>

                                <!--  Top spinner  -->
                                <Grid
                                    x:Name="PART_SpinnerTop"
                                    Width="14"
                                    Height="14"
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Center"
                                    DockPanel.Dock="Top"
                                    RenderTransformOrigin="0.5,0.5"
                                    Visibility="Collapsed">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="SpinnerTopRotate" Angle="0" />
                                    </Grid.RenderTransform>
                                    <Ellipse
                                        StrokeDashArray="15.71 3.14"
                                        StrokeDashCap="Round"
                                        StrokeThickness="2">
                                        <Ellipse.Stroke>
                                            <Binding Path="Foreground" RelativeSource="{RelativeSource TemplatedParent}" />
                                        </Ellipse.Stroke>
                                    </Ellipse>
                                </Grid>

                                <!--  Right spinner  -->
                                <Grid
                                    x:Name="PART_SpinnerRight"
                                    Width="14"
                                    Height="14"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Right"
                                    RenderTransformOrigin="0.5,0.5"
                                    Visibility="Collapsed">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRightRotate" Angle="0" />
                                    </Grid.RenderTransform>
                                    <Ellipse
                                        StrokeDashArray="15.71 3.14"
                                        StrokeDashCap="Round"
                                        StrokeThickness="2">
                                        <Ellipse.Stroke>
                                            <Binding Path="Foreground" RelativeSource="{RelativeSource TemplatedParent}" />
                                        </Ellipse.Stroke>
                                    </Ellipse>
                                </Grid>

                                <!--  Bottom spinner  -->
                                <Grid
                                    x:Name="PART_SpinnerBottom"
                                    Width="14"
                                    Height="14"
                                    Margin="0,6,0,0"
                                    HorizontalAlignment="Center"
                                    DockPanel.Dock="Bottom"
                                    RenderTransformOrigin="0.5,0.5"
                                    Visibility="Collapsed">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="SpinnerBottomRotate" Angle="0" />
                                    </Grid.RenderTransform>
                                    <Ellipse
                                        StrokeDashArray="15.71 3.14"
                                        StrokeDashCap="Round"
                                        StrokeThickness="2">
                                        <Ellipse.Stroke>
                                            <Binding Path="Foreground" RelativeSource="{RelativeSource TemplatedParent}" />
                                        </Ellipse.Stroke>
                                    </Ellipse>
                                </Grid>

                                <!--  Icon + Content (fills remaining DockPanel space)  -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter
                                        x:Name="ControlIcon"
                                        Grid.Column="0"
                                        Margin="{StaticResource ButtonIconMargin}"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding Icon}"
                                        Focusable="False"
                                        TextElement.FontSize="{TemplateBinding FontSize}"
                                        TextElement.Foreground="{TemplateBinding Foreground}" />

                                    <ContentPresenter
                                        x:Name="ContentPresenter"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        RecognizesAccessKey="True"
                                        TextElement.Foreground="{TemplateBinding Foreground}" />
                                </Grid>
                            </DockPanel>
                        </Border>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!--  Mouse over (not pressed)  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsPressed" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ContentBorder" Property="Background" Value="{Binding MouseOverBackground, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="ContentBorder" Property="BorderBrush" Value="{Binding MouseOverBorderBrush, RelativeSource={RelativeSource TemplatedParent}}" />
                        </MultiTrigger>

                        <!--  Pressed  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ContentBorder" Property="Background" Value="{Binding PressedBackground, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="ContentBorder" Property="BorderBrush" Value="{Binding PressedBorderBrush, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="ContentPresenter" Property="TextElement.Foreground" Value="{Binding PressedForeground, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="ControlIcon" Property="TextElement.Foreground" Value="{Binding PressedForeground, RelativeSource={RelativeSource TemplatedParent}}" />
                        </MultiTrigger>

                        <!--  Disabled  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource ButtonBackgroundDisabled}" />
                            <Setter TargetName="ContentBorder" Property="BorderBrush" Value="{DynamicResource ButtonBorderBrushDisabled}" />
                            <Setter TargetName="ControlIcon" Property="TextElement.Foreground" Value="{DynamicResource ButtonForegroundDisabled}" />
                            <Setter TargetName="ContentPresenter" Property="TextElement.Foreground" Value="{DynamicResource ButtonForegroundDisabled}" />
                        </Trigger>

                        <!--  Icon margin — hide gap when there is no content  -->
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter TargetName="ControlIcon" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="Content" Value="">
                            <Setter TargetName="ControlIcon" Property="Margin" Value="0" />
                        </Trigger>

                        <!--  No icon — collapse icon presenter  -->
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="ControlIcon" Property="Margin" Value="0" />
                            <Setter TargetName="ControlIcon" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  Secondary appearance — move border to outer Border  -->
                        <Trigger Property="Appearance" Value="Secondary">
                            <Setter TargetName="InsetBorder" Property="BorderThickness" Value="0" />
                            <Setter TargetName="ContentBorder" Property="BorderThickness" Value="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>

                        <!--  Show spinner by placement  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsLoading" Value="True" />
                                <Condition Property="LoadingPlacement" Value="Left" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_SpinnerLeft" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsLoading" Value="True" />
                                <Condition Property="LoadingPlacement" Value="Right" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_SpinnerRight" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsLoading" Value="True" />
                                <Condition Property="LoadingPlacement" Value="Top" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_SpinnerTop" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsLoading" Value="True" />
                                <Condition Property="LoadingPlacement" Value="Bottom" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_SpinnerBottom" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!--
                            Spin animation — all four spinners start together so the
                            correct one (whichever is visible) is already spinning.
                        -->
                        <Trigger Property="IsLoading" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="SpinnerLeftSB">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="SpinnerLeftRotate"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="360"
                                            Duration="0:0:0.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                                <BeginStoryboard x:Name="SpinnerTopSB">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="SpinnerTopRotate"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="360"
                                            Duration="0:0:0.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                                <BeginStoryboard x:Name="SpinnerRightSB">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="SpinnerRightRotate"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="360"
                                            Duration="0:0:0.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                                <BeginStoryboard x:Name="SpinnerBottomSB">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="SpinnerBottomRotate"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="360"
                                            Duration="0:0:0.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="SpinnerLeftSB" />
                                <StopStoryboard BeginStoryboardName="SpinnerTopSB" />
                                <StopStoryboard BeginStoryboardName="SpinnerRightSB" />
                                <StopStoryboard BeginStoryboardName="SpinnerBottomSB" />
                            </Trigger.ExitActions>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Implicit style (picked up by DefaultStyleKeyProperty.OverrideMetadata)  -->
    <Style BasedOn="{StaticResource DefaultLoadingButtonStyle}" TargetType="{x:Type local:LoadingButton}" />

</ResourceDictionary>
