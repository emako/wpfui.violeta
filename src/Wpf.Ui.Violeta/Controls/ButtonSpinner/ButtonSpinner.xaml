<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Wpf.Ui.Violeta.Controls"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!--  Shared sizes  -->
    <system:Double x:Key="ButtonSpinnerButtonWidth">22</system:Double>
    <system:Double x:Key="ButtonSpinnerButtonHeight">14</system:Double>
    <system:Double x:Key="ButtonSpinnerSplitButtonSize">28</system:Double>

    <!--  Internal RepeatButton style (grouped variant — stacked ▲/▼)  -->
    <Style x:Key="ButtonSpinnerRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Border.CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="Width" Value="{StaticResource ButtonSpinnerButtonWidth}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding Border.CornerRadius}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Internal RepeatButton style (split variant — full-height ◄/►)  -->
    <Style x:Key="ButtonSpinnerSplitRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextControlElevationBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Border.CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="Width" Value="{StaticResource ButtonSpinnerSplitButtonSize}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding Border.CornerRadius}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
        Default ButtonSpinner style.
        Buttons are grouped (▲ over ▼) and placed to the right (or left) of the content.
    -->
    <Style TargetType="{x:Type local:ButtonSpinner}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource TextControlBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextControlElevationBorderBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource TextBoxBorderThemeThickness}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
        <Setter Property="Padding" Value="{DynamicResource TextControlThemePadding}" />
        <Setter Property="MinHeight" Value="{DynamicResource TextControlThemeMinHeight}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Border.CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ButtonSpinner}">
                    <Grid>
                        <Border
                            x:Name="ContentBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding Border.CornerRadius}"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!--  Button group (Left placement)  -->
                                    <ColumnDefinition x:Name="LeftButtonColumn" Width="0" />
                                    <!--  Content  -->
                                    <ColumnDefinition Width="*" />
                                    <!--  Button group (Right placement)  -->
                                    <ColumnDefinition x:Name="RightButtonColumn" Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Spin button group  -->
                                <Grid
                                    x:Name="PART_ButtonGroup"
                                    Grid.Column="2"
                                    VerticalAlignment="Center">
                                    <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                                        <RepeatButton
                                            x:Name="PART_IncreaseButton"
                                            Height="{StaticResource ButtonSpinnerButtonHeight}"
                                            Style="{StaticResource ButtonSpinnerRepeatButtonStyle}">
                                            <TextBlock
                                                FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                FontSize="9"
                                                Text="&#xE70E;" />
                                        </RepeatButton>
                                        <RepeatButton
                                            x:Name="PART_DecreaseButton"
                                            Height="{StaticResource ButtonSpinnerButtonHeight}"
                                            Style="{StaticResource ButtonSpinnerRepeatButtonStyle}">
                                            <TextBlock
                                                FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                FontSize="9"
                                                Text="&#xE70D;" />
                                        </RepeatButton>
                                    </StackPanel>
                                </Grid>

                                <!--  Content area  -->
                                <ContentPresenter
                                    x:Name="PART_ContentPresenter"
                                    Grid.Column="1"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                            </Grid>
                        </Border>

                        <!--  Focus accent border  -->
                        <Border
                            x:Name="AccentBorder"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="{DynamicResource TextBoxAccentBorderThemeThickness}"
                            CornerRadius="{TemplateBinding Border.CornerRadius}"
                            IsHitTestVisible="False" />
                    </Grid>

                    <ControlTemplate.Triggers>

                        <!--  Buttons on the left  -->
                        <Trigger Property="ButtonSpinnerLocation" Value="Left">
                            <Setter TargetName="LeftButtonColumn" Property="Width" Value="Auto" />
                            <Setter TargetName="RightButtonColumn" Property="Width" Value="0" />
                            <Setter TargetName="PART_ButtonGroup" Property="Grid.Column" Value="0" />
                        </Trigger>

                        <!--  ShowButtonSpinner = False  -->
                        <Trigger Property="ShowButtonSpinner" Value="False">
                            <Setter TargetName="PART_ButtonGroup" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="LeftButtonColumn" Property="Width" Value="0" />
                            <Setter TargetName="RightButtonColumn" Property="Width" Value="0" />
                        </Trigger>

                        <!--  Keyboard focus  -->
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="AccentBorder" Property="BorderThickness" Value="0,0,0,2" />
                            <Setter TargetName="AccentBorder" Property="BorderBrush" Value="{DynamicResource TextControlFocusedBorderBrush}" />
                            <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource TextControlBackgroundFocused}" />
                        </Trigger>

                        <!--  Hover  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsKeyboardFocusWithin" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource TextControlBackgroundPointerOver}" />
                        </MultiTrigger>

                        <!--  Disabled  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource TextControlBackgroundDisabled}" />
                            <Setter TargetName="ContentBorder" Property="BorderBrush" Value="{DynamicResource TextControlBorderBrushDisabled}" />
                            <Setter TargetName="AccentBorder" Property="BorderBrush" Value="{DynamicResource TextControlBorderBrushDisabled}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        SplitButtonSpinner style.
        Mirrors Semi's SplitButtonSpinner:  [−] [content] [+]
        Use:  Style="{DynamicResource SplitButtonSpinnerStyle}"
    -->
    <Style x:Key="SplitButtonSpinnerStyle" TargetType="{x:Type local:ButtonSpinner}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource TextControlBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextControlElevationBorderBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource TextBoxBorderThemeThickness}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
        <Setter Property="Padding" Value="{DynamicResource TextControlThemePadding}" />
        <Setter Property="MinHeight" Value="{DynamicResource TextControlThemeMinHeight}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Border.CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ButtonSpinner}">
                    <Border
                        x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding Border.CornerRadius}"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!--  − button  -->
                                <ColumnDefinition x:Name="DecreaseColumn" Width="Auto" />
                                <!--  Content  -->
                                <ColumnDefinition Width="*" />
                                <!--  + button  -->
                                <ColumnDefinition x:Name="IncreaseColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <RepeatButton
                                x:Name="PART_DecreaseButton"
                                Grid.Column="0"
                                VerticalAlignment="Stretch"
                                Style="{StaticResource ButtonSpinnerSplitRepeatButtonStyle}">
                                <TextBlock
                                    FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                    FontSize="10"
                                    Text="&#xE921;" />
                            </RepeatButton>

                            <ContentPresenter
                                x:Name="PART_ContentPresenter"
                                Grid.Column="1"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />

                            <RepeatButton
                                x:Name="PART_IncreaseButton"
                                Grid.Column="2"
                                VerticalAlignment="Stretch"
                                Style="{StaticResource ButtonSpinnerSplitRepeatButtonStyle}">
                                <TextBlock
                                    FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                    FontSize="10"
                                    Text="&#xE710;" />
                            </RepeatButton>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!--  Buttons on the left = swap columns  -->
                        <Trigger Property="ButtonSpinnerLocation" Value="Left">
                            <Setter TargetName="PART_DecreaseButton" Property="Grid.Column" Value="2" />
                            <Setter TargetName="PART_ContentPresenter" Property="Grid.Column" Value="1" />
                            <Setter TargetName="PART_IncreaseButton" Property="Grid.Column" Value="0" />
                        </Trigger>

                        <!--  ShowButtonSpinner = False  -->
                        <Trigger Property="ShowButtonSpinner" Value="False">
                            <Setter TargetName="PART_DecreaseButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_IncreaseButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  Hover  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsKeyboardFocusWithin" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource TextControlBackgroundPointerOver}" />
                        </MultiTrigger>

                        <!--  Disabled  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource TextControlBackgroundDisabled}" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource TextControlBorderBrushDisabled}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
