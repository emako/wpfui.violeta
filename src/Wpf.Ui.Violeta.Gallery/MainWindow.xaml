<vio:ShellWindow
    x:Class="Wpf.Ui.Violeta.Gallery.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:compat="clr-namespace:Wpf.Ui.Violeta.Controls.Compat;assembly=Wpf.Ui.Violeta"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
    Title="Wpf.Ui.Violeta Gallery"
    Width="1280"
    Height="800"
    d:Background="#1C1C1C"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Theme Switcher in TitleBar area  -->
        <StackPanel
            Grid.Row="0"
            Margin="16,42,16,8"
            HorizontalAlignment="Left"
            Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="主题" />
            <ComboBox
                x:Name="ThemeComboBox"
                MinWidth="100"
                Margin="8,0,0,0"
                SelectionChanged="ThemeComboBox_OnSelectionChanged">
                <ComboBoxItem Content="跟随系统" />
                <ComboBoxItem Content="深色" IsSelected="True" />
                <ComboBoxItem Content="浅色" />
            </ComboBox>
        </StackPanel>

        <!--  NavigationView  -->
        <vio:NavigationView
            x:Name="GalleryNav"
            Grid.Row="1"
            Margin="16,0,16,16"
            AlwaysShowHeader="True"
            BackRequested="GalleryNav_OnBackRequested"
            CompactPaneLength="52"
            Header="欢迎"
            IsBackButtonVisible="Visible"
            IsBackEnabled="False"
            IsPaneOpen="True"
            IsPaneToggleButtonVisible="True"
            IsSettingsVisible="True"
            OpenPaneLength="240"
            PaneTitle="Violeta Gallery"
            SelectionChanged="GalleryNav_OnSelectionChanged">

            <vio:NavigationView.MenuItems>
                <vio:NavigationViewItem
                    x:Name="HomeItem"
                    Content="主页"
                    Tag="home">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE80F;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>

                <vio:NavigationViewItemHeader Content="通知与对话" />

                <vio:NavigationViewItem Content="Toast 通知" Tag="toast">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xEA0C;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>

                <vio:NavigationViewItem Content="对话框" Tag="dialog">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE8B7;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>

                <vio:NavigationViewItemHeader Content="数据输入" />

                <vio:NavigationViewItem Content="输入控件" Tag="input">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE773;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>

                <vio:NavigationViewItemHeader Content="数据展示" />

                <vio:NavigationViewItem Content="数据控件" Tag="data">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE9D9;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>

                <vio:NavigationViewItemHeader Content="反馈与状态" />

                <vio:NavigationViewItem Content="反馈控件" Tag="feedback">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE895;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>

                <vio:NavigationViewItemHeader Content="布局与装饰" />

                <vio:NavigationViewItem Content="布局控件" Tag="layout">
                    <vio:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE8C1;" />
                    </vio:NavigationViewItem.Icon>
                </vio:NavigationViewItem>
            </vio:NavigationView.MenuItems>

            <!--  Page Content Frame  -->
            <compat:Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden" />
        </vio:NavigationView>
    </Grid>
</vio:ShellWindow>
