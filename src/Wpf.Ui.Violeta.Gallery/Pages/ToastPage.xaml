<vio:Page
    x:Class="Wpf.Ui.Violeta.Gallery.Pages.ToastPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
    Title="Toast 通知"
    d:Background="#1C1C1C"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="24,16,24,24" d:DataContext="{d:DesignInstance IsDesignTimeCreatable=False}">

            <TextBlock
                Margin="0,0,0,16"
                FontSize="20"
                FontWeight="SemiBold"
                Text="Toast 通知" />

            <!--  Toast Types  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="通知类型" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="默认" />
                        <WrapPanel Grid.Row="0" Grid.Column="1">
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopCenter"
                                Tag="None|TopCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopRight"
                                Tag="None|TopRight" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="BottomCenter"
                                Tag="None|BottomCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="Center"
                                Tag="None|Center" />
                        </WrapPanel>

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="信息" />
                        <WrapPanel Grid.Row="2" Grid.Column="1">
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopCenter"
                                Tag="Information|TopCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopRight"
                                Tag="Information|TopRight" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="BottomCenter"
                                Tag="Information|BottomCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="Center"
                                Tag="Information|Center" />
                        </WrapPanel>

                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="成功" />
                        <WrapPanel Grid.Row="4" Grid.Column="1">
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopCenter"
                                Tag="Success|TopCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopRight"
                                Tag="Success|TopRight" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="BottomCenter"
                                Tag="Success|BottomCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="Center"
                                Tag="Success|Center" />
                        </WrapPanel>

                        <TextBlock
                            Grid.Row="6"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="错误" />
                        <WrapPanel Grid.Row="6" Grid.Column="1">
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopCenter"
                                Tag="Error|TopCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopRight"
                                Tag="Error|TopRight" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="BottomCenter"
                                Tag="Error|BottomCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="Center"
                                Tag="Error|Center" />
                        </WrapPanel>

                        <TextBlock
                            Grid.Row="8"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="警告" />
                        <WrapPanel Grid.Row="8" Grid.Column="1">
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopCenter"
                                Tag="Warning|TopCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopRight"
                                Tag="Warning|TopRight" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="BottomCenter"
                                Tag="Warning|BottomCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="Center"
                                Tag="Warning|Center" />
                        </WrapPanel>

                        <TextBlock
                            Grid.Row="10"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="问题" />
                        <WrapPanel Grid.Row="10" Grid.Column="1">
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopCenter"
                                Tag="Question|TopCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="TopRight"
                                Tag="Question|TopRight" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="BottomCenter"
                                Tag="Question|BottomCenter" />
                            <ui:Button
                                Margin="0,0,8,4"
                                Click="ShowToast_Click"
                                Content="Center"
                                Tag="Question|Center" />
                        </WrapPanel>

                    </Grid>
                </StackPanel>
            </Border>

            <!--  Toast Stacking  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="堆叠测试" />
                    <WrapPanel>
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ShowStacked_Click"
                            Content="显示 5 条堆叠通知" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ShowNonStacked_Click"
                            Content="非堆叠模式" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ShowLimitedStack_Click"
                            Content="限制堆叠（最多 2 条）" />
                    </WrapPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</vio:Page>
