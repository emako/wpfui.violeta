<vio:Page
    x:Class="Wpf.Ui.Violeta.Gallery.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
    Title="设置"
    d:Background="#1C1C1C"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="24,16,24,24">

            <TextBlock
                Margin="0,0,0,16"
                FontSize="20"
                FontWeight="SemiBold"
                Text="应用设置" />

            <!--  Appearance  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="外观" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="切换应用主题，支持跟随系统、深色与浅色模式。" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="主题" />
                        <ComboBox
                            x:Name="ThemeComboBox"
                            Grid.Column="1"
                            MinWidth="160"
                            Margin="16,0,0,0"
                            HorizontalAlignment="Left"
                            SelectionChanged="ThemeComboBox_OnSelectionChanged">
                            <ComboBoxItem Content="跟随系统" />
                            <ComboBoxItem Content="深色" IsSelected="True" />
                            <ComboBoxItem Content="浅色" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!--  About  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="关于" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Wpf.Ui.Violeta Gallery — 控件演示与交互验证应用。"
                        TextWrapping="Wrap" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="库版本" />
                        <TextBlock
                            x:Name="LibraryVersionText"
                            Grid.Column="1"
                            Text="Wpf.Ui.Violeta 4.3.0.2" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="运行时" />
                        <TextBlock
                            x:Name="RuntimeVersionText"
                            Grid.Column="1"
                            Text="-" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="仓库" />
                        <TextBlock
                            Grid.Column="1"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="github.com/emako/wpfui.violeta"
                            TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <!--  NavigationView settings note  -->
            <Border
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <ui:FontIcon
                        HorizontalAlignment="Left"
                        FontFamily="{DynamicResource SymbolThemeFontFamily}"
                        FontSize="20"
                        Glyph="&#xE713;" />
                    <TextBlock
                        Margin="0,10,0,0"
                        FontWeight="SemiBold"
                        Text="NavigationView 设置项" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="本页通过 NavigationView 底部设置按钮（IsSettingsVisible）导航进入，用于演示 SettingsItem 选中与页面切换联动。"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</vio:Page>
