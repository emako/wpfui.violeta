<vio:Page
    x:Class="Wpf.Ui.Violeta.Gallery.Pages.InputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
    Title="输入控件"
    d:Background="#1C1C1C"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="24,16,24,24">

            <TextBlock
                Margin="0,0,0,16"
                FontSize="20"
                FontWeight="SemiBold"
                Text="数据输入控件" />

            <!--  MultiComboBox  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="MultiComboBox — 多选下拉框" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="支持多选、标签展示、搜索过滤。" />
                    <vio:MultiComboBox
                        x:Name="MultiComboBoxDemo"
                        MaxWidth="400"
                        HorizontalAlignment="Left"
                        SelectionChanged="MultiComboBoxDemo_OnSelectionChanged" />
                    <TextBlock
                        x:Name="MultiComboBoxResultText"
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="已选择：(无)" />
                </StackPanel>
            </Border>

            <!--  TagComboBox  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="TagComboBox — 标签下拉框" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="以标签形式展示选项，支持搜索。" />
                    <vio:TagComboBox
                        x:Name="TagComboBoxDemo"
                        MaxWidth="400"
                        HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!--  TagInput  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="TagInput — 标签输入框" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="输入回车/逗号创建新标签，支持删除。" />
                    <vio:TagInput MaxWidth="400" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!--  CascadingComboBox  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="CascadingComboBox — 级联下拉框" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="父子级联选择，选中父项后展示对应子选项。" />
                    <StackPanel Orientation="Horizontal">
                        <vio:CascadingComboBox
                            x:Name="CascadingLevel1"
                            Width="160"
                            Margin="0,0,8,0"
                            PlaceholderText="省份"
                            SelectionChanged="CascadingLevel1_SelectionChanged" />
                        <vio:CascadingComboBox
                            x:Name="CascadingLevel2"
                            Width="160"
                            Margin="0,0,8,0"
                            IsEnabled="False"
                            PlaceholderText="城市" />
                    </StackPanel>
                    <TextBlock
                        x:Name="CascadingResultText"
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="已选择：(无)" />
                </StackPanel>
            </Border>

            <!--  NumericUpDown  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="NumericUpDown — 数值调节" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="支持最小/最大值、步进、格式化显示。" />
                    <StackPanel Orientation="Horizontal">
                        <vio:NumericIntUpDown
                            Width="160"
                            Margin="0,0,16,0"
                            Maximum="100"
                            Minimum="0"
                            Value="42" />
                        <vio:NumericDecimalUpDown
                            Width="160"
                            Maximum="100"
                            Minimum="0"
                            Value="3.14" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  ButtonSpinner  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="ButtonSpinner — 旋转按钮" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="通过上下箭头切换值，支持默认/左侧/分割三种布局。" />
                    <StackPanel Orientation="Horizontal">
                        <vio:ButtonSpinner
                            Margin="0,0,16,0"
                            AllowSpin="True"
                            Spin="ButtonSpinner_OnSpin">
                            <TextBlock
                                x:Name="SpinnerValueText"
                                MinWidth="80"
                                HorizontalAlignment="Center"
                                Text="Apple" />
                        </vio:ButtonSpinner>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  IPv4Box  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="IPv4Box — IP 地址输入" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="专用 IPv4 地址输入框，自动校验范围（0–255）。" />
                    <vio:IPv4Box MaxWidth="220" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!--  TimeBox  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="TimeBox — 时间输入" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="分段时间输入框，支持键盘和鼠标滚轮调节。" />
                    <vio:TimeBox MaxWidth="200" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!--  DateTimePicker  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="DateTimePicker — 日期时间选择" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="弹出日历面板选择日期，内置时间段选择。" />
                    <StackPanel Orientation="Horizontal">
                        <vio:DatePicker
                            MaxWidth="200"
                            Margin="0,0,16,0"
                            HorizontalAlignment="Left" />
                        <vio:TimePicker MaxWidth="200" HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  PinCode  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="PinCode — PIN 码输入" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="分格 PIN 码输入框，支持密码模式和自定义长度。" />
                    <vio:PinCode HorizontalAlignment="Left" Count="6" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</vio:Page>
