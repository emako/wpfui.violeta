<vio:Page
    x:Class="Wpf.Ui.Violeta.Gallery.Pages.DialogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
    Title="对话框"
    d:Background="#1C1C1C"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="24,16,24,24">

            <TextBlock
                Margin="0,0,0,16"
                FontSize="20"
                FontWeight="SemiBold"
                Text="对话框" />

            <!--  ContentDialog  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="ContentDialog" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Violeta 版 ContentDialog，支持异步显示、主/次/关闭按钮。" />
                    <WrapPanel>
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ShowContentDialog_Click"
                            Content="显示 ContentDialog" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ShowContentDialogCustom_Click"
                            Content="自定义内容" />
                    </WrapPanel>
                    <TextBlock
                        x:Name="ContentDialogResultText"
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="结果：(等待操作)" />
                </StackPanel>
            </Border>

            <!--  MessageBox  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="MessageBox" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="带图标的消息框，支持同步和异步两种调用方式。" />
                    <WrapPanel>
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ShowMessageBox_Click"
                            Content="信息"
                            Tag="Information" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ShowMessageBox_Click"
                            Content="警告"
                            Tag="Warning" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ShowMessageBox_Click"
                            Content="问题"
                            Tag="Question" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ShowMessageBox_Click"
                            Content="错误"
                            Tag="Error" />
                    </WrapPanel>
                    <TextBlock
                        x:Name="MessageBoxResultText"
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="结果：(等待操作)" />
                </StackPanel>
            </Border>

            <!--  PendingBox  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="PendingBox" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="异步等待对话框，可显示进度和取消按钮，适合后台任务。" />
                    <WrapPanel>
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ShowPendingBox_Click"
                            Content="模拟加载任务" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Click="ShowPendingBoxWithCancel_Click"
                            Content="可取消的任务" />
                    </WrapPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</vio:Page>
