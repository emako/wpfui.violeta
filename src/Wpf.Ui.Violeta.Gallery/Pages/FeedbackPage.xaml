<vio:Page
    x:Class="Wpf.Ui.Violeta.Gallery.Pages.FeedbackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
    Title="反馈控件"
    d:Background="#1C1C1C"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="24,16,24,24">

            <TextBlock
                Margin="0,0,0,16"
                FontSize="20"
                FontWeight="SemiBold"
                Text="反馈与状态控件" />

            <!--  BusyIndicator  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="BusyIndicator — 忙碌指示器" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="旋转加载动画，适合在内容区域内嵌显示加载状态。" />
                    <StackPanel Orientation="Horizontal">
                        <vio:Indicator
                            Width="40"
                            Height="40"
                            Margin="0,0,16,0" />
                        <vio:Indicator
                            Width="24"
                            Height="24"
                            Margin="0,0,16,0" />
                        <vio:Indicator Width="16" Height="16" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Skeleton  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Skeleton — 骨架屏" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="用于内容加载前的占位显示，提升用户体验。" />
                    <StackPanel>
                        <vio:Skeleton Height="20" Margin="0,0,0,8" />
                        <vio:Skeleton
                            Height="20"
                            MaxWidth="360"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Left" />
                        <vio:Skeleton
                            Height="20"
                            MaxWidth="280"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  BoolStateContentControl  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="BoolStateContentControl — 布尔状态内容" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="根据布尔值显示不同内容，点击切换状态。" />
                    <StackPanel Orientation="Horizontal">
                        <CheckBox
                            x:Name="BoolStateCheckBox"
                            VerticalAlignment="Center"
                            Content="激活状态" />
                        <vio:BoolStateContentControl Margin="16,0,0,0" Value="{Binding IsChecked, ElementName=BoolStateCheckBox}">
                            <vio:BoolStateContentControl.TrueContent>
                                <Border
                                    Padding="12,6"
                                    Background="#1A90D040"
                                    BorderBrush="#90D040"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <TextBlock Foreground="#90D040" Text="● 已激活" />
                                </Border>
                            </vio:BoolStateContentControl.TrueContent>
                            <vio:BoolStateContentControl.FalseContent>
                                <Border
                                    Padding="12,6"
                                    Background="#1AFF4444"
                                    BorderBrush="#FF4444"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <TextBlock Foreground="#FF4444" Text="○ 未激活" />
                                </Border>
                            </vio:BoolStateContentControl.FalseContent>
                        </vio:BoolStateContentControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Expander  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Expander — 展开器" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="折叠 / 展开面板，适合设置项或详情区域。" />
                    <Expander Header="点击展开详情">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="这里是展开后的详细内容区域。" />
                            <TextBlock
                                Margin="0,4,0,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="可以放置任意控件，例如表单、列表、图片等。" />
                        </StackPanel>
                    </Expander>
                    <Expander Margin="0,8,0,0" Header="另一个展开器">
                        <TextBlock
                            Margin="0,8,0,0"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="多个展开器可独立控制展开状态。" />
                    </Expander>
                </StackPanel>
            </Border>

            <!--  TransitioningContentControl  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="TransitioningContentControl — 过渡内容" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="内容切换时播放过渡动画，支持多种动画方向。" />
                    <StackPanel>
                        <Border
                            Height="60"
                            Margin="0,0,0,8"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="6">
                            <vio:TransitioningContentControl
                                x:Name="TransitionContent"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Transition="Right">
                                <TextBlock
                                    x:Name="TransitionText"
                                    FontSize="16"
                                    Text="Slide 1 — 欢迎使用 Violeta" />
                            </vio:TransitioningContentControl>
                        </Border>
                        <WrapPanel>
                            <ui:Button
                                Margin="0,0,8,8"
                                Click="PrevSlide_Click"
                                Content="◀ 上一个" />
                            <ui:Button
                                Margin="0,0,8,8"
                                Click="NextSlide_Click"
                                Content="下一个 ▶" />
                            <ComboBox
                                x:Name="TransitionTypeComboBox"
                                Margin="0,0,0,8"
                                SelectionChanged="TransitionType_SelectionChanged">
                                <ComboBoxItem
                                    Content="Right"
                                    IsSelected="True"
                                    Tag="Right" />
                                <ComboBoxItem Content="Left" Tag="Left" />
                                <ComboBoxItem Content="Up" Tag="Up" />
                                <ComboBoxItem Content="Down" Tag="Down" />
                                <ComboBoxItem Content="Normal" Tag="Normal" />
                            </ComboBox>
                        </WrapPanel>
                        <TextBlock
                            x:Name="TransitionStatusText"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Slide 1/4 | Right" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</vio:Page>
