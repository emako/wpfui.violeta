                                TimeMemberPath="Time" />
                            <vio:Timeline
                                Margin="0,0,24,0"
                                ContentMemberPath="Description"
                                HeaderMemberPath="Header"
                                ItemsSource="{Binding TimelineItems}"
                                Mode="Left"
                                TimeFormat="yyyy-MM-dd"
                                TimeMemberPath="Time" />
                            <vio:Timeline
                                Margin="0,0,24,0"
                                ContentMemberPath="Description"
                                HeaderMemberPath="Header"
                                ItemsSource="{Binding TimelineItems}"
