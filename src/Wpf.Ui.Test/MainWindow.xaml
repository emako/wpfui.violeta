                        FontSize="14"
                        FontWeight="Black"
                        Text="RangeSlider" />

                    <StackPanel Margin="0,8,0,0">
                        <!--  Horizontal (basic)  -->
                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                            <TextBlock
                                MinWidth="160"
                                VerticalAlignment="Center"
                                Text="Horizontal" />
                            <vio:RangeSlider
                                Width="320"
                                LowerValue="{Binding RangeSliderLower, Mode=TwoWay}"
                                Maximum="100"
                                Minimum="0"
                                UpperValue="{Binding RangeSliderUpper, Mode=TwoWay}" />
                            <TextBlock
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Text="{Binding RangeSliderText}" />
                        </StackPanel>

                        <!--  Horizontal with ticks (snap)  -->
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <TextBlock
                                MinWidth="160"
                                VerticalAlignment="Center"
                                Text="Ticks + Snap" />
                            <vio:RangeSlider
                                Width="320"
                                IsSnapToTickEnabled="True"
                                LowerValue="{Binding RangeSliderTickLower, Mode=TwoWay}"
                                Maximum="100"
                                Minimum="0"
                                TickFrequency="10"
                                TickPlacement="BottomRight"
                                UpperValue="{Binding RangeSliderTickUpper, Mode=TwoWay}" />
                            <TextBlock
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Text="{Binding RangeSliderTickText}" />
                        </StackPanel>

                        <!--  Vertical  -->
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <TextBlock
                                MinWidth="160"
                                VerticalAlignment="Center"
                                Text="Vertical" />
                            <vio:RangeSlider
                                Height="160"
                                LowerValue="20"
                                Maximum="100"
                                Minimum="0"
                                Orientation="Vertical"
                                UpperValue="80" />
                        </StackPanel>

                        <!--  Vertical with ticks  -->
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <TextBlock
                                MinWidth="160"
                                VerticalAlignment="Center"
                                Text="Vertical + Ticks" />
                            <vio:RangeSlider
                                Height="160"
                                LowerValue="30"
                                Maximum="100"
                                Minimum="0"
                                Orientation="Vertical"
                                TickFrequency="10"
                                TickPlacement="Both"
                                UpperValue="70" />
                        </StackPanel>

                        <!--  Disabled  -->
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <TextBlock
                                MinWidth="160"
                                VerticalAlignment="Center"
                                Text="Disabled" />
                            <vio:RangeSlider
                                Width="320"
                                IsEnabled="False"
                                LowerValue="25"
                                Maximum="100"
                                Minimum="0"
                                UpperValue="75" />
                        </StackPanel>

                        <!--  Read-only  -->
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <TextBlock
                                MinWidth="160"
                                VerticalAlignment="Center"
                                Text="ReadOnly" />
                            <vio:RangeSlider
                                Width="320"
                                IsReadOnly="True"
                                LowerValue="30"
                                Maximum="100"
                                Minimum="0"
                                UpperValue="60" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Anchor  -->
                    <StackPanel x:Name="AnchorDemoSection" Margin="0,24,24,0">
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="Anchor" />

                        <!--  Two-panel layout: anchor nav on the left, content on the right  -->
                        <Grid Height="360">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  Anchor nav  -->
                            <vio:Anchor
                                x:Name="DemoAnchor"
                                Grid.Column="0"
                                VerticalAlignment="Top"
                                TargetContainer="{Binding ElementName=AnchorScrollViewer}"
                                TopOffset="12">
                                <vio:AnchorItem AnchorId="sec1" Header="Section 1" />
                                <vio:AnchorItem AnchorId="sec2" Header="Section 2">
                                    <vio:AnchorItem AnchorId="sec2-1" Header="Sub-section 2.1" />
                                    <vio:AnchorItem AnchorId="sec2-2" Header="Sub-section 2.2" />
                                </vio:AnchorItem>
                                <vio:AnchorItem AnchorId="sec3" Header="Section 3" />
                                <vio:AnchorItem AnchorId="sec4" Header="Section 4" />
                                <vio:AnchorItem AnchorId="sec5" Header="Section 5" />
                            </vio:Anchor>

                            <!--  Scrollable content  -->
                            <ScrollViewer
                                x:Name="AnchorScrollViewer"
                                Grid.Column="1"
                                Padding="12,0"
                                VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock
                                        vio:Anchor.Id="sec1"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="Section 1" />
                                    <TextBlock
                                        Margin="0,4,0,32"
                                        Text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris."
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        vio:Anchor.Id="sec2"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="Section 2" />
                                    <TextBlock
                                        Margin="0,4,0,8"
                                        Text="Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur."
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,12,0,0"
                                        vio:Anchor.Id="sec2-1"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="Sub-section 2.1" />
                                    <TextBlock
                                        Margin="0,4,0,8"
                                        Text="Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum."
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,12,0,0"
                                        vio:Anchor.Id="sec2-2"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="Sub-section 2.2" />
                                    <TextBlock
                                        Margin="0,4,0,32"
                                        Text="Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium totam rem aperiam eaque ipsa quae ab illo inventore veritatis."
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        vio:Anchor.Id="sec3"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="Section 3" />
                                    <TextBlock
                                        Margin="0,4,0,32"
                                        Text="Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt."
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        vio:Anchor.Id="sec4"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="Section 4" />
                                    <TextBlock
                                        Margin="0,4,0,32"
                                        Text="Neque porro quisquam est, qui dolorem ipsum quia dolor sit amet, consectetur, adipisci velit, sed quia non numquam eius modi tempora incidunt."
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        vio:Anchor.Id="sec5"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="Section 5" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        Text="Ut labore et dolore magnam aliquam quaerat voluptatem. Ut enim ad minima veniam, quis nostrum exercitationem ullam corporis suscipit laboriosam."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </StackPanel>

                    <!--  ═══════════════════════════════════════════════════════  -->
                    <!--  TransitioningContentControl  -->
                    <!--  ═══════════════════════════════════════════════════════  -->
                    <TextBlock
                        FontSize="14"
                        FontWeight="Black"
                        Text="TransitioningContentControl" />
                    <StackPanel Margin="0,8,0,12">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button
                                Margin="0,0,8,0"
                                Command="{Binding PreviousTransitioningDemoCommand}"
                                Content="Previous" />
                            <ui:Button
                                Margin="0,0,12,0"
                                Command="{Binding NextTransitioningDemoCommand}"
                                Content="Next" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding TransitioningDemoStatus}" />
                        </StackPanel>

                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Text="Transition:" />
                            <ui:Button
                                Margin="8,0,0,0"
                                Command="{Binding SetTransitioningDemoTransitionCommand}"
                                CommandParameter="Right"
                                Content="Right" />
                            <ui:Button
                                Margin="8,0,0,0"
                                Command="{Binding SetTransitioningDemoTransitionCommand}"
                                CommandParameter="Left"
                                Content="Left" />
                            <ui:Button
                                Margin="8,0,0,0"
                                Command="{Binding SetTransitioningDemoTransitionCommand}"
                                CommandParameter="Up"
                                Content="Up" />
                            <ui:Button
                                Margin="8,0,0,0"
                                Command="{Binding SetTransitioningDemoTransitionCommand}"
                                CommandParameter="Down"
                                Content="Down" />
                            <ui:Button
                                Margin="8,0,0,0"
                                Command="{Binding SetTransitioningDemoTransitionCommand}"
                                CommandParameter="Default"
                                Content="Default" />
                        </StackPanel>

                        <vio:TransitioningContentControl
                            Margin="0,10,0,0"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Top"
                            Content="{Binding TransitioningDemoContent}"
                            RestartTransitionOnContentChange="True"
                            Transition="{Binding TransitioningDemoTransition}">
                            <vio:TransitioningContentControl.ContentTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="16"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                        BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="Transitioning content" />
                                            <TextBlock
                                                Margin="0,6,0,0"
                                                FontSize="18"
                                                FontWeight="SemiBold"
                                                Text="{Binding}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </vio:TransitioningContentControl.ContentTemplate>
                        </vio:TransitioningContentControl>

                        <!--  SelectableTextBlock  -->
                        <!--  =============================  -->
                        <TextBlock
                            FontSize="14"
                            FontWeight="Black"
                            Text="SelectableTextBlock" />
                        <StackPanel Margin="0,8,0,16">
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Default" />
                                <vio:SelectableTextBlock Text="Default — drag to select, right-click to copy." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Secondary" />
                                <vio:SelectableTextBlock Style="{StaticResource SecondarySelectableTextBlock}" Text="Secondary text colour." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Tertiary" />
                                <vio:SelectableTextBlock Style="{StaticResource TertiarySelectableTextBlock}" Text="Tertiary text colour." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Quaternary" />
                                <vio:SelectableTextBlock Style="{StaticResource QuaternarySelectableTextBlock}" Text="Quaternary (disabled) text colour." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Success" />
                                <vio:SelectableTextBlock Style="{StaticResource SuccessSelectableTextBlock}" Text="Success text colour." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Warning" />
                                <vio:SelectableTextBlock Style="{StaticResource WarningSelectableTextBlock}" Text="Warning text colour." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Danger" />
                                <vio:SelectableTextBlock Style="{StaticResource DangerSelectableTextBlock}" Text="Danger text colour." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Mark (highlight)" />
                                <vio:SelectableTextBlock Style="{StaticResource MarkSelectableTextBlock}" Text="Mark highlight background." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Underline" />
                                <vio:SelectableTextBlock Style="{StaticResource UnderlineSelectableTextBlock}" Text="Underline decoration." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Delete (strikethrough)" />
                                <vio:SelectableTextBlock Style="{StaticResource DeleteSelectableTextBlock}" Text="Strikethrough decoration." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Underline + Delete" />
                                <vio:SelectableTextBlock Style="{StaticResource UnderlineDeleteSelectableTextBlock}" Text="Underline and strikethrough combined." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Disabled" />
                                <vio:SelectableTextBlock IsEnabled="False" Text="Disabled state." />
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    Text="Multi-line wrap" />
                                <vio:SelectableTextBlock
                                    MaxWidth="300"
                                    Text="This is a longer paragraph of text that wraps across multiple lines. You can select any part of it with the mouse and copy it to the clipboard." />
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </ui:Grid>
        <ui:TitleBar Title="Wpf.Ui.Test" />
    </Grid>
</vio:ShellWindow>
