                            <vio:Divider>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Star24" />
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="Custom Content" />
                                </StackPanel>
                            </vio:Divider>
                            <!--  Vertical dividers  -->
                            <ui:StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Text="Left" />
                                <vio:Divider Orientation="Vertical" />
                                <TextBlock VerticalAlignment="Center" Text="Middle" />
                                <vio:Divider Orientation="Vertical" />
                                <TextBlock VerticalAlignment="Center" Text="Right" />
                            </ui:StackPanel>
                        </ui:StackPanel>
                    </StackPanel>
                    <StackPanel>
                        <!--  =============================  -->
                        <TextBlock
