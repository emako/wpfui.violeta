                                    LoadingPlacement="Left" />
                                <vio:LoadingButton
                                    Margin="0,0,8,0"
                                    Content="Right"
                                    IsLoading="True"
                                    LoadingPlacement="Right" />
                                <vio:LoadingButton
                                    Margin="0,0,8,0"
                                    Content="Top"
                                    IsLoading="True"
                                    LoadingPlacement="Top" />
                                <vio:LoadingButton
                                    Content="Bottom"
                                    IsLoading="True"
                                    LoadingPlacement="Bottom" />
