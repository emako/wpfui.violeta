                                    Height="48"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4" />
                            </vio:Badge>
                            <!--  Dot  -->
                            <vio:Badge Margin="16" Dot="True">
                                <Border
                                    Width="48"
                                    Height="48"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4" />
                            </vio:Badge>
                            <!--  BottomRight  -->
                            <vio:Badge
                                Margin="16"
                                BadgeContent="3"
                                CornerPosition="BottomRight">
                                <Border
