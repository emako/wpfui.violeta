                                    Content="Submit"
                                    IsLoading="{Binding IsLoadingButtonCommandLoading}"
                                    LoadingPlacement="Left" />
                                <vio:LoadingButton
                                    Margin="0,0,8,0"
                                    Appearance="Primary"
                                    Command="{Binding SimulateLoadingButtonCommand}"
                                    Content="Submit"
                                    IsLoading="{Binding IsLoadingButtonCommandLoading}"
                                    LoadingPlacement="Left" />
                                <vio:LoadingButton
                                    Appearance="Danger"
                                    Command="{Binding SimulateLoadingButtonCommand}"
                                    Content="Submit"
                                    IsLoading="{Binding IsLoadingButtonCommandLoading}"
                                    LoadingPlacement="Left" />
                            </StackPanel>
                        </StackPanel>
