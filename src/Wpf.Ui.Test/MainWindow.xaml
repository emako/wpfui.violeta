                            <vio:KeyGestureInput
                                x:Name="ClearableGestureInput"
                                Width="240"
                                Margin="4"
                                ClearButtonEnabled="True"
                                IsReadOnly="True"
                                PlaceholderText="Press shortcut, then clear..." />
                        </WrapPanel>
                    </StackPanel>
                    <StackPanel>
                        <!--  =============================  -->
                        <TextBlock
                            MinWidth="120"
                            Margin="0,8,0,0"
                            FontSize="14"
                            FontWeight="Black"
                            Text="Divider" />
                        <ui:StackPanel Margin="0,4,0,0" Spacing="8">
                            <!--  No content (plain line)  -->
                            <vio:Divider />
                            <!--  Center label (default)  -->
                            <vio:Divider Content="Center" />
                            <!--  Left label  -->
                            <vio:Divider HorizontalContentAlignment="Left" Content="Left" />
                            <!--  Right label  -->
                            <vio:Divider HorizontalContentAlignment="Right" Content="Right" />
