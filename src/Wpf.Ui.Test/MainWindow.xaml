                            Margin="0,8,0,0"
                            FontSize="14"
                            FontWeight="Black"
                            Text="LoadingButton" />
                        <StackPanel Margin="0,8,0,16">
                            <!--  Placement  -->
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="160"
                                    VerticalAlignment="Center"
                                    Text="Placement" />
                                <vio:LoadingButton
                                    Margin="0,0,8,0"
                                    Content="Left"
