                    <StackPanel>
                        <!--  =============================  -->
                        <TextBlock
                            MinWidth="120"
                            Margin="0,8,0,0"
                            FontSize="14"
                            FontWeight="Black"
                            Text="KeyGestureInput" />
                        <WrapPanel>
                            <!--  Default (with modifiers)  -->
                            <vio:KeyGestureInput
                                Width="240"
                                Margin="4"
                                Gesture="{Binding KeyGesture, Mode=TwoWay}" />
                            <!--  No modifiers  -->
                            <vio:KeyGestureInput
                                Width="240"
                                Margin="4"
                                ConsiderKeyModifiers="False"
                                PlaceholderText="Press any single key..." />
