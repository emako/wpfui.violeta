                                TimeFormat="yyyy-MM-dd"
                                TimeMemberPath="Time" />
                            <vio:Timeline Mode="Alternate">
                                <vio:TimelineItem
                                    Content="First item"
                                    Header="Step One"
                                    Position="Left"
                                    Type="Default" />
                                <vio:TimelineItem
                                    Content="Second item"
                                    Header="Step Two"
                                    Position="Right"
                                    Type="Success" />
                                <vio:TimelineItem
                                    Content="Third item"
                                    Header="Step Three"
                                    Position="Separate"
                                    Type="Warning" />
                                <vio:TimelineItem
                                    Content="Fourth item"
                                    Header="Step Four"
                                    Position="Separate"
                                    Type="Ongoing" />
                                <vio:TimelineItem
                                    Content="Fifth item"
                                    Header="Step Five"
                                    Position="Separate"
                                    Type="Error" />
