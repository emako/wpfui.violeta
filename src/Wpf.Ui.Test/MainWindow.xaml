                                    Margin="0,0,8,0"
                                    Appearance="Primary"
                                    Content="Primary"
                                    IsLoading="{Binding IsLoadingButtonLoading}"
                                    LoadingPlacement="Right" />
                                <vio:LoadingButton
                                    Margin="0,0,8,0"
                                    Appearance="Danger"
                                    Content="Danger"
                                    IsLoading="{Binding IsLoadingButtonLoading}"
