                                    MinWidth="160"
                                    Margin="0,6,0,0"
                                    VerticalAlignment="Top"
                                    Text="Separator (,)" />
                                <vio:TagInput
                                    Width="320"
                                    PlaceholderText="Type or paste comma-separated…"
