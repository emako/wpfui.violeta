                                    Margin="0,0,8,0"
                                    Appearance="Primary"
                                    Content="Primary"
                                    IsLoading="True"
                                    LoadingPlacement="Left" />
                                <vio:LoadingButton
                                    Margin="0,0,8,0"
                                    Appearance="Danger"
                                    Content="Danger"
                                    IsLoading="True"
                                    LoadingPlacement="Left" />
                                <vio:LoadingButton
                                    Appearance="Success"
                                    Content="Success"
                                    IsLoading="True"
                                    LoadingPlacement="Left" />
                            </StackPanel>
                            <!--  No content (icon-only spinner)  -->
                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="160"
                                    VerticalAlignment="Center"
                                    Text="No content" />
                                <vio:LoadingButton
                                    Margin="0,0,8,0"
                                    Appearance="Secondary"
                                    IsLoading="True"
                                    LoadingPlacement="Left" />
                                <vio:LoadingButton
                                    Margin="0,0,8,0"
                                    Appearance="Primary"
                                    IsLoading="True"
                                    LoadingPlacement="Left" />
                            </StackPanel>
                            <!--  Disabled  -->
                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="160"
                                    VerticalAlignment="Center"
                                    Text="Disabled" />
                                <vio:LoadingButton
                                    Margin="0,0,8,0"
                                    Content="Not Loading"
                                    IsEnabled="False"
                                    IsLoading="False" />
                                <vio:LoadingButton
                                    Margin="0,0,8,0"
                                    Appearance="Primary"
                                    Content="Loading + Disabled"
                                    IsEnabled="False"
                                    IsLoading="True"
                                    LoadingPlacement="Left" />
                            </StackPanel>
                            <!--  Dynamic toggle  -->
                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <TextBlock
                                    MinWidth="160"
                                    VerticalAlignment="Center"
                                    Text="Dynamic toggle" />
